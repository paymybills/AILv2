{
  "name": "ail-extension",
  "displayName": "AIL_extension",
  "description": "KG graphs/LLM extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ail-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "ail-extension.runAIL",
        "title": "Run AIL Analysis"
      }
    ],
    "configuration": {
      "title": "AIL",
      "properties": {
        "ail.azureOpenAiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Your Azure OpenAI endpoint URL (e.g. https://my-resource.openai.azure.com/)"
        },
        "ail.azureOpenAiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Azure OpenAI API key"
        },
        "ail.azureOpenAiDeployment": {
          "type": "string",
          "default": "gpt-4o",
          "description": "The deployment name of your Chat model in Azure OpenAI"
        },
        "ail.azureOpenAiEmbedDeployment": {
          "type": "string",
          "default": "text-embedding-3-small",
          "description": "The deployment name of your Embeddings model in Azure OpenAI"
        },
        "ail.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Google Gemini API Key"
        },
        "ail.geminiModel": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "description": "The Gemini model to use for chat (selected at launch)"
        },
        "ail.aiProvider": {
          "type": "string",
          "enum": [
            "azure",
            "gemini"
          ],
          "default": "",
          "description": "The AI provider to use for RAG and Chat (selected at launch)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "tree-sitter-cli": "^0.26.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8"
  }
}